---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import home from '../data/home.json';
import services from '../data/services.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Picture } from 'astro:assets';
import image1 from '../assets/images/team.jpg';
import image2 from '../assets/images/car.jpg';
import image3 from '../assets/images/uniform.jpg';
import image4 from '../assets/images/landscape.jpg';
import Icon from '../components/Icon.astro';
import ClientsSticker from '../components/ClientsSticker.astro';
import ButtonToAction from '../components/ButtonToAction.astro';
import IconValues from '../components/IconValues.astro';

type ClientName = Parameters<typeof ClientsSticker>[0]['name'];
---

<Layout title="ARVISEG" pageId="home">
  <Hero hero={home.hero} />

  <button id="test-scroll">Ir a About (prueba)</button>

  <section class="mb-30 mt-15 grid gap-12">
    <p class="max-w-[450px] px-12 text-2xl text-center justify-self-center">
      Oferecemos nuestros servicios a una variedad de clientes.
    </p>

    <!-- Carrusel infinito -->
    <div class="carousel-container overflow-hidden">
      <div class="carousel-track flex gap-16 px-8">
        <!-- Primera copia de las imagenes -->
        {
          home.clients.map((client: string) => (
            <ClientsSticker
              name={client as ClientName}
              class="filter-carousel max-w-26 object-contain m-4"
            />
          ))
        }
        <!-- Segunda copia para efecto infinito -->
        {
          home.clients.map((client: string) => (
            <ClientsSticker
              name={client as ClientName}
              class="filter-carousel max-w-26 object-contain m-4"
            />
          ))
        }
      </div>
    </div>
  </section>
  <section class="px-12 py-8 grid gap-12 m-auto">
    <h3 class="text-primary text-2xl w-40 text-center justify-self-center">
      NUESTROS SERVICIOS
    </h3>
    <div class="max-w-[1000px] flex flex-wrap gap-8 justify-center m-auto">
      {
        services.list.map((service) => (
          <>
            <div class="services-content justify-items-center text-center">
              <div class="flex w-[60px]">
                <Icon
                  name={
                    service.icon as
                      | 'shield'
                      | 'monitor'
                      | 'vip'
                      | 'camera'
                      | 'fence'
                      | 'values'
                  }
                />
              </div>
              <h3 class="text-lg font-semibold mt-3">{service.title}</h3>
            </div>
          </>
        ))
      }
    </div>
    <a
      href="/services/"
      class="bg-primary action-hover text-dark py-2 px-4 justify-self-center"
      >Conocer más</a
    >
  </section>

  <section id="about" class="px-12 py-8 my-12 grid gap-20">
    <article class="relative grid gap-12">
      <Picture
        class="image-1 w-full max-w-[520px] justify-self-center sm:justify-self-end sm:relative md:top-20"
        src={image1}
        formats={['jpg']}
        alt="team arviseg"
      />
      <div class="grid gap-16 max-w-[450px]">
        <h3 class="text-primary uppercase text-2xl">{home.about.title}</h3>
        <p>{home.about.description}</p>
      </div>
    </article>
    <article
      class="grid gap-12 relative md:flex md:flex-row-reverse md:justify-between"
    >
      <div class="grid gap-12 max-w-[380px] justify-self-end">
        <h3 class="text-primary uppercase text-4xl">{home.mission.title}</h3>
        <p>{home.mission.description}</p>
      </div>
      <Picture
        class="image-2 w-full max-w-[410px] relative md:top-10"
        src={image2}
        formats={['jpg']}
        alt="car arviseg"
      />
    </article>
    <div class="grid gap-12 md:mt-8 max-w-[420px]">
      <h3 class="text-primary uppercase text-4xl">{home.vision.title}</h3>
      <p>{home.vision.description}</p>
    </div>
    <article class="grid justify-center lg:justify-end relative lg:-top-25">
      <Picture
        class="image-3 w-full max-w-[480px] lg:mr-15"
        src={image3}
        formats={['jpg']}
        alt="uniform arviseg"
      />
      <div
        class="bg-primary text-dark max-w-[400px] sm:max-w-[450px] relative bottom-8 transform -translate-x-4 sm:-translate-x-20 px-6 py-4"
      >
        <p>{home.experience.label}</p>
        <p>{home.experience.years}</p>
      </div>
    </article>
  </section>

  <section class="grid text-center gap-12">
    <div class="relative grid justify-items-center">
      <Picture
        class="image-4 w-full max-w-[1024px] min-h-[210px] object-cover"
        src={image4}
        formats={['jpg']}
        alt="uniform arviseg"
      />
      <div class="absolute bottom-6">
        <ButtonToAction />
      </div>
    </div>

    <div class="grid gap-12">
      <h3 class="text-primary uppercase text-2xl w-[220px] justify-self-center">
        Valores Institucionales
      </h3>
      <IconValues name="integrity" />
    </div>
  </section>
  <Footer />
</Layout>

<script>
  document.getElementById('test-scroll')?.addEventListener('click', () => {
    const about = document.getElementById('about');
    if (about) {
      about.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
</script>

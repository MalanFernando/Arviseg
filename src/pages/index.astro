---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import home from '../data/home.json';
import services from '../data/services.json';
import Footer from '../components/Footer.astro';
import { Picture } from 'astro:assets';
import image1 from '../assets/images/team.jpg';
import image2 from '../assets/images/car.jpg';
import image3 from '../assets/images/uniform.jpg';
import image4 from '../assets/images/landscape.jpg';
import Icon from '../components/Icon.astro';
import ClientsSticker from '../components/ClientsSticker.astro';
import ButtonToAction from '../components/ButtonToAction.astro';
import IconValues from '../components/IconValues.astro';
import Ecuador from '../components/Ecuador.astro';

type ClientName = Parameters<typeof ClientsSticker>[0]['name'];
---

<Layout title="ARVISEG" pageId="home">
  <Hero hero={home.hero} />

  <section id="clientes" class="mb-30 mt-15 grid gap-16">
    <p
      class="fade-up text-color-hover max-w-[520px] px-12 text-3xl sm:text-4xl text-center justify-self-center font-bold"
    >
      <span class="font-normal text-color">Oferecemos nuestros servicios</span> a
      una variedad de clientes.
    </p>

    <!-- Carrusel infinito -->
    <div class="fade-up carousel-container overflow-hidden">
      <div class="carousel-track flex gap-16 px-8">
        <!-- Primera copia de las imagenes -->
        {
          home.clients.map((client: string) => (
            <ClientsSticker
              name={client as ClientName}
              class="filter-carousel max-w-27 object-contain m-4"
            />
          ))
        }
        <!-- Segunda copia para efecto infinito -->
        {
          home.clients.map((client: string) => (
            <ClientsSticker
              name={client as ClientName}
              class="filter-carousel max-w-27 object-contain m-4"
            />
          ))
        }
      </div>
    </div>
  </section>
  <section id="serv" class="px-4 sm:px-8 py-8 grid gap-12 m-auto">
    <h3
      class="fade-up text-xl max-w-40 text-center justify-self-center font-semibold"
    >
      NUESTROS <span class="text-4xl text-color-hover">SERVICIOS</span>
    </h3>
    <div
      class="max-w-[900px] flex flex-wrap justify-center gap-5 sm:gap-8 md:gap-16 m-auto"
    >
      {
        services.list.map((service, i) => {
          const delayClass =
            i < 4 ? `delay-${i + 1}` : `delay-${Math.min(i, 4)}`;
          return (
            <>
              <div
                id="serv-icons"
                class={`fade-up ${delayClass} services-content justify-items-center text-center`}
              >
                <div class="flex max-w-[60px]">
                  <Icon
                    name={
                      service.icon as
                        | 'shield'
                        | 'monitor'
                        | 'vip'
                        | 'camera'
                        | 'fence'
                        | 'values'
                    }
                  />
                </div>
                <h3 class="mt-3 w-[120px] sm:w-full">{service.title}</h3>
              </div>
            </>
          );
        })
      }
    </div>
    <a
      href="/services/"
      class="fade-up bg-primary action-hover text-dark py-2 px-4 mt-6 justify-self-center"
      >Conocer más</a
    >
  </section>

  <section
    id="about"
    class="seccion-ecuador-v2 demo-svg px-8 sm:px-12 py-8 my-12 grid gap-20"
  >
    <Ecuador />
    <article class="abt relative grid gap-12">
      <Picture
        class="fade-up image-1 w-full max-w-[620px] justify-self-center sm:justify-self-end sm:relative lg:top-20"
        src={image1}
        formats={['webp', 'jpg']}
        alt="Equipo de seguridad ARVISEG en formación"
      />
      <div class="grid gap-16 max-w-[450px]">
        <h3 class="fade-up text-primary uppercase text-2xl font-semibold">
          {home.about.title}
        </h3>
        <div>
          <p class="fade-up text-3xl font-semibold pb-2 max-w-[380px]">
            {home.about.bigdescription}
          </p>
          <p class="fade-up">{home.about.description}</p>
        </div>
      </div>
    </article>
    <article
      class="abt grid gap-12 sm:gap-8 relative lg:flex lg:flex-row-reverse lg:justify-between"
    >
      <div class="grid gap-12 max-w-[380px] justify-self-end">
        <h3 class="fade-up text-primary uppercase text-2xl font-semibold">
          {home.mission.title}
        </h3>
        <div>
          <p class="fade-up text-3xl font-semibold">
            {home.mission.bigdescription}
          </p>
          <p class="fade-up">{home.mission.description}</p>
        </div>
      </div>
      <Picture
        class="fade-up image-2 w-full max-w-[420px] relative md:top-10"
        src={image2}
        formats={['webp', 'jpg']}
        alt="Vehículo de patrullaje de ARVISEG"
      />
    </article>
    <div class="grid gap-16 md:mt-8 max-w-[450px]">
      <h3 class="fade-up text-primary uppercase text-2xl font-semibold">
        {home.vision.title}
      </h3>
      <div>
        <p class="fade-up text-3xl font-semibold pb-2">
          {home.vision.bigdescription}
        </p>
        <p class="fade-up">{home.vision.description}</p>
      </div>
    </div>
    <article
      class="abt grid justify-center lg:justify-end relative lg:-top-20 xl:-top-30"
    >
      <Picture
        class="fade-up image-3 w-full max-w-[580px] lg:mr-15"
        src={image3}
        formats={['webp', 'jpg']}
        alt="Personal de ARVISEG con uniforme oficial"
      />
      <div
        id="experience-label"
        class="fade-up bg-primary text-dark max-w-[400px] sm:max-w-[490px] justify-self-center lg:justify-self-start lg:-left-30 text-center relative bottom-10 px-6 py-4"
      >
        <p class="fade-up">{home.experience.label}</p>
        <p class="fade-up text-2xl font-semibold">
          +<span class="text-4xl font-bold">22 </span>{home.experience.years}
        </p>
      </div>
    </article>
  </section>

  <section id="values" class="grid text-center gap-12">
    <div class="relative grid justify-items-center">
      <Picture
        class="fade-up image-4 w-full max-w-[1024px] min-h-[250px] object-cover"
        src={image4}
        formats={['webp', 'jpg']}
        alt="Equipo completo de ARVISEG en ambiente laboral"
      />
      <div class="absolute bottom-9">
        <ButtonToAction />
      </div>
    </div>

    <div class="grid gap-12">
      <h3
        class="fade-up text-xl uppercase w-[220px] justify-self-center font-bold"
      >
        Valores <span class="text-3xl text-primary">Institucionales</span>
      </h3>
      <IconValues name="integrity" />
    </div>
  </section>
  <Footer />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document
    .querySelectorAll(
      '.fade-up, .fade-in, .fade-in-slow, .slide-left, .fade-down'
    )
    .forEach((el) => observer.observe(el));
</script>

---
import Layout from '../layouts/Layout.astro';
import home from '../data/home.json';
import services from '../data/services.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Picture } from 'astro:assets';
import image3 from '../assets/images/uniform.jpg';
import cic from '../assets/logo-certificacion/cic-logo.png';
import ClientsSticker from '../components/ClientsSticker.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ButtonToAction from '../components/ButtonToAction.astro';

type ClientName = Parameters<typeof ClientsSticker>[0]['name'];
---

<Layout title="ARVISEG servicios">
  <Header />

  <section class="px-12 py-8">
    <div>
      <ButtonToAction />
    </div>
  </section>

  <section class="px-12 my-20 grid gap-12">
    <div class="px-12 grid gap-12 justify-items-center">
      <h4 class="uppercase text-2xl">Nuestros Servicios</h4>
      <p class="max-w-[480px]">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Dolor ullam
        dignissimos harum beatae perspiciatis ad pariatur. Velit labore
        doloremque tempora sunt nisi beatae, natus atque deleniti eum rerum
        neque minima!
      </p>
    </div>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {services.list.map((service) => <ServiceCard service={service} />)}
    </div>
  </section>

  <section class="py-8 grid gap-25">
    <div class="px-12 grid gap-12 justify-items-center">
      <h4 class="uppercase text-2xl">Valor agregado</h4>
      <p class="max-w-[480px]">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Dolor ullam
        dignissimos harum beatae perspiciatis ad pariatur. Velit labore
        doloremque tempora sunt nisi beatae, natus atque deleniti eum rerum
        neque minima!
      </p>
    </div>

    <div class="relative">
      <Picture
        class="w-full max-w-[760px] justify-self-center sm:justify-self-start lg:ml-12"
        src={image3}
        formats={['jpg']}
        alt="team arviseg"
      />
      <article
        class="max-w-[740px] 2xl:max-w-[820px] p-8 mx-4 sm:mx-8 lg:mx-12 grid gap-2 justify-self-end relative -top-10 sm:-top-20 md:-top-45"
      >
        {
          services.value_added.map((value) => (
            <div class="flex items-start gap-4">
              <p>{value}</p>
            </div>
          ))
        }
        <p>
          Lorem ipsum dolor sit amet, consectetur adipisicing elit.
          Exercitationem debitis, delectus officiis magni deleniti temporibus,
          quas eos, ducimus tempore repellat iusto quasi sequi totam voluptates
          ipsa provident vitae placeat sit!
        </p>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipisicing elit.
          Exercitationem debitis, delectus officiis magni deleniti temporibus,
          quas eos, ducimus tempore repellat iusto quasi sequi totam voluptates
          ipsa provident vitae placeat sit!
        </p>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipisicing elit.
          Exercitationem debitis, delectus officiis magni deleniti temporibus,
          quas eos, ducimus tempore repellat iusto quasi sequi totam voluptates
          ipsa provident vitae placeat sit!
        </p>
      </article>
    </div>
  </section>

  <section class="relative px-12 sm:-top-10 md:-top-30">
    <div class="px-12 grid gap-12 justify-items-center">
      <Picture
        class="relative sm:left-40 sm:top-25 sm:rotate-10"
        src={cic}
        formats={['png']}
        alt="cic logo certificacion"
      />
      <h4 class="uppercase text-2xl">Certificaciones</h4>
      <p class="max-w-[480px] text-center">
        ARVISEG CIA. LTDA, ha sido evaluado, aprobado con respecto a los
        requisitos especificados y certificado según las normas internacionales
      </p>
    </div>
    <div class="flex flex-wrap gap-12 mt-12 justify-center">
      {
        services.certifications.map((certification) => (
          <div class="flex p-4">
            <p>{certification}</p>
          </div>
        ))
      }
    </div>
  </section>
  <Footer />
</Layout>

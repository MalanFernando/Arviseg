---
import Layout from '../layouts/Layout.astro';
import services from '../data/services.json';
import Footer from '../components/Footer.astro';
import { Picture } from 'astro:assets';
import resguard from '../assets/images/resguard.jpg';
import landscape2 from '../assets/images/landscape2.jpg';
import cic from '../assets/logo-certificacion/cic-logo.png';
import ClientsSticker from '../components/ClientsSticker.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ButtonToAction from '../components/ButtonToAction.astro';

type ClientName = Parameters<typeof ClientsSticker>[0]['name'];
---

<Layout title="ARVISEG servicios" pageId="services">
  <section class="w-full relative grid">
      <Picture
        class="image-5 w-full max-h-[520px] min-h-[420px] -top-22 object-cover relative left-0 -z-10"
        src={landscape2}
        formats={['webp', 'jpg']}
        alt="Paisaje corporativo ARVISEG"
      />
    <div
      class="grid gap-8 text-center justify-items-center justify-self-center self-center absolute"
    >
      <div>
        <span class="fade-up text-3xl uppercase font-bold">Nuestros</span>
        <h3
          class="fade-up text-primary text-4xl sm:text-5xl md:text-7xl font-bold uppercase"
        >
          Servicios
        </h3>
      </div>
      <ButtonToAction className="delay-1" />
    </div>
  </section>

  <section id="services-section" class="px-8 sm:px-12 mb-20 mt-15 grid gap-40">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
      <div class="">
        <h4 class="fade-up text-primary uppercase text-xl font-semibold">
          Que hacemos
        </h4>
        <p class="fade-up delay-1 text-3xl mt-12 pr-4">
          Hacemos que la seguridad de su negocio, hogar o bienestar personal sea
          <span class="font-bold text-color-hover"
            >verdaderamente efectiva.</span
          >
        </p>
      </div>
      {services.list.map((service) => <ServiceCard service={service} />)}
    </div>
  </section>

  <section id="value-add-section" class="py-8 grid gap-25">
    <div class="px-12 grid gap-12 justify-items-center text-center">
      <h4 class="fade-up max-w-[180px] uppercase text-2xl font-semibold">
        Valor <span class="text-4xl text-primary">agregado</span>
      </h4>
      <p class="fade-up delay-1 text-2xl max-w-[560px] font-bold">
        <span class="font-normal brightness-75"
          >Nuestros Guardias de Seguridad cuentan con el</span
        > curso de 120 horas aprobado por el Ministerio del Interior de la República
        del Ecuador
      </p>
    </div>

    <div class="relative">
      <Picture
        class="fade-up image-6 w-full max-w-[760px] justify-self-center sm:justify-self-start lg:ml-12"
        src={resguard}
        formats={['webp', 'jpg']}
        alt="Guardia de seguridad ARVISEG en servicio"
      />
      <article
        id="services-list"
        class="fade-up delay-1 bg-primary text-black max-w-[740px] 2xl:max-w-[820px] px-8 sm:px-10 py-8 mx-4 sm:mx-8 lg:mx-12 grid gap-2 justify-self-end relative -top-10 sm:-top-20 md:-top-45"
      >
        {
          services.value_added.map((value) => (
            <div class="fade-in flex items-start gap-4">
              <p class="max-w-[610px]">&middot; {value}</p>
            </div>
          ))
        }
      </article>
    </div>
  </section>

  <section id="certf" class="relative px-4 sm:px-12 sm:-top-10 md:-top-30">
    <div class="px-12 grid gap-12 justify-items-center">
      <Picture
        class="fade-up relative sm:left-48 sm:top-25 sm:rotate-8"
        src={cic}
        formats={['webp', 'png']}
        alt="Certificación CIC - ARVISEG"
      />
      <h4 class="fade-up delay-1 text-primary uppercase text-3xl font-bold">
        Certificaciones
      </h4>
      <p class="fade-up delay-2 max-w-[520px] text-center text-xl">
        ARVISEG CIA. LTDA, ha sido evaluado, aprobado con respecto a los
        requisitos especificados y <span class="font-bold text-color-hover"
          >certificado según las normas internacionales</span
        >
      </p>
    </div>
    <div class="flex flex-wrap gap-12 mt-16 justify-center">
      {
        services.certifications.map((certification) => (
          <div class="bg-primary text-black fade-up delay-3 flex px-6 py-2 text-xl rounded-[90px]">
            <p>{certification}</p>
          </div>
        ))
      }
    </div>
  </section>
  <Footer />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document
    .querySelectorAll(
      '.fade-up, .fade-in, .fade-in-slow, .slide-left, .fade-down'
    )
    .forEach((el) => observer.observe(el));
</script>

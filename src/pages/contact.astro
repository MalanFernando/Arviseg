---
import { Picture } from 'astro:assets';
import ContactForm from '../components/ContactForm.astro';
import contact from '../data/contact.json';
import Layout from '../layouts/Layout.astro';
import SocialIcons from '../components/SocialIcons.astro';
import logo from '../assets/logos/logo-arviseg.png';
import Map from '../components/Map.astro';
---

<Layout title="ARVISEG contactos" pageId="contact">
  <section
    class="form-section image-7 sm:px-12 py-8 pt-40 grid gap-8 relative -top-18"
  >
    <div class="px-6 sm:px-0 grid gap-8">
      <h2 class="fade-up text-primary text-3xl sm:text-6xl uppercase font-bold">
        Contáctanos
      </h2>
      <p class="fade-up delay-1 max-w-[320px] text-lg">
        Av. Reina Victoria N13-95 y Colón. Edif. Banco de Guayaquil, Piso PH
      </p>
    </div>
    <div class="px-2 grid md:grid-flow-row-dense lg:grid-cols-3 gap-12">
      <div class="px-6 sm:px-0 grid gap-4">
        <div>
          <h3
            class="fade-up delay-2 text-primary h-fit max-w-[200px] text-2xl font-semibold"
          >
            Tu seguridad en nuestras manos
          </h3>
          <div class="grid gap-4 h-fit mt-8">
            <h4 class="fade-up delay-3 text-primary uppercase font-bold">
              Contactos
            </h4>
            <div class="info-contacts">
              <ul>
                {
                  contact.info.phones.map((phone, i) => (
                    <li class={`fade-up delay-${i + 1} mb-2`}>{phone}</li>
                  ))
                }
              </ul>
              <ul>
                {
                  contact.info.emails.map((mail, i) => (
                    <li class={`fade-up delay-${i + 1} mb-1`}>
                      <a class="mails" href={`mailto:${mail}`}>
                        {mail}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
        <div class="self-end">
          <SocialIcons animate={true} />
        </div>
      </div>
      <ContactForm />
    </div>
  </section>
  <section class="pt-8 grid gap-8">
    <h3
      class="fade-up px-12 text-primary text-3xl sm:text-5xl uppercase font-bold"
    >
      Como Encontrarnos
    </h3>
    <div class="md:px-12">
      <Map />
    </div>
  </section>

  <footer class="lines px-12 pt-4 pb-4 border-t border-red-500 mt-15">
    <section
      class="grid sm:grid-cols-2 lg:grid-cols-4 justify-between gap-12 mb-4 pt-8"
    >
      <div class="fade-up h-fit flex items-start gap-4">
        <Picture
          class="size-14"
          src={logo}
          formats={['png']}
          alt="logo arviseg"
        />
        <h3 class="text-primary text-2xl sm:text-3xl self-center font-bold">
          ARVISEG
        </h3>
      </div>
    </section>
    <div
      class="lines flex gap-4 flex-wrap justify-center sm:justify-between mt-14 pt-4"
    >
      <p class="fade-up delay-1">
        &copy; {new Date().getFullYear()} ARVISEG. Todos los derechos reservados.
      </p>
      <p class="fade-up delay-1">
        Diseñado y desarrollado por <a
          class="zentro"
          href="https://www.instagram.com/zentro.ec_/">zentro.ec</a
        >
      </p>
    </div>
  </footer>
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document
    .querySelectorAll('.fade-up, .fade-in, .fade-in-slow, .slide-left, .fade-down')
    .forEach((el) => observer.observe(el));
</script>

---
import ButtonUp from '../components/ButtonUp.astro';
import Header from '../components/Header.astro';
import WhatsappButton from '../components/WhatsappButton.astro';
import '../styles/global.css';
const { pageId, title = 'Arviseg' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      if (sessionStorage.getItem('arviseg-home-animated')) {
        document.documentElement.classList.add('anim-done');
      }
    </script>
  </head>
  <body id={pageId} class="max-w-[1440px] m-auto">
    <div class="content-buttons grid gap-4">
      <ButtonUp />
      <WhatsappButton />
    </div>
    <Header pageId={pageId} />
    <slot />

    <script>
      function closeMobileMenu() {
        const menu = document.getElementById('mobile-menu');
        const mainBar = document.getElementById('main-bar');
        const hamburger = document.getElementById('hamburger');
        const close = document.getElementById('close');

        if (!menu || menu.classList.contains('hidden')) return;

        menu.classList.add('hidden');
        menu.classList.remove('flex');
        mainBar?.classList.remove('menu-open');

        if (hamburger && close) {
          hamburger.classList.remove('hidden');
          close.classList.add('hidden');
        }
      }

      window.addEventListener('hashchange', () => {
        closeMobileMenu();
      });
    </script>
  </body>
</html>

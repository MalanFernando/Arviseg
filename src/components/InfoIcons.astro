---
import home from '../data/home.json';
---

<ul class="grid md:flex gap-4 md:gap-12 md:overflow-x-hidden">
  <!-- Teléfono -->
  <li class="min-w-max">
    <svg
      class="text-secondary inline relative -top-[2px] mr-1"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
      ></path>
    </svg>
    <span class="">{home.minibanner.telf}</span>
  </li>

  <!-- Email -->
  <li class="min-w-max">
    <svg
      class="text-secondary inline relative -top-[2px] mr-1"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
      ></path>
      <polyline points="22,6 12,13 2,6"></polyline>
    </svg>
    <a class="mails" href="mailto:{home.minibanner.email}"
      >{home.minibanner.email}</a
    >
  </li>

  <!-- Dirección -->
  <li class="sm:min-w-max">
    <svg
      class="text-secondary inline relative -top-[2px] mr-1"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
      <circle cx="12" cy="10" r="3"></circle>
    </svg>
    <span>{home.minibanner.address}</span>
  </li>
</ul>

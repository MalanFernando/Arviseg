---
// components/MapWithCard.astro
---

<div class="map-section fade-in-slow">
  <div
    class="map-wrapper h-[250px] sm:h-[300px] md:h-[450px] grayscale brightness-80 hue-rotate-15 hover:grayscale-0"
  >
    <!-- Iframe del mapa -->
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.793865080375!2d-78.49125452582263!3d-0.20060763540149035!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91d59b9f5770e6db%3A0xd4d0b785ee6e8145!2sARVISEG%20Cia.%20Ltda.%20-%20Seguridad%20Privada!5e0!3m2!1sen!2sec!4v1777258550543!5m2!1sen!2sec"
      title="Ubicación de ARVISEG en Google Maps"
      width="100%"
      height="450"
      style="position:relative; top: -5px;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="strict-origin-when-cross-origin"></iframe>
  </div>
</div>

<style>
  .map-section {
    position: relative;
    width: 100%;
  }

  .map-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
</style>

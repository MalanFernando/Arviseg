---
import Icon from './Icon.astro';

const { service } = Astro.props;
---

<div class="cards fade-up p-8 gap-8">
  <button
    class="btn-cotizar"
    data-service={service.title}
    aria-label="Solicitar cotización"
  >
    Cotizar
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="7" y1="17" x2="17" y2="7"></line>
      <polyline points="7 7 17 7 17 17"></polyline>
    </svg>
  </button>
  <div class="flex max-w-[60px]">
    <Icon name={service.icon} />
  </div>
  <div class="grid gap-6">
    <h3 class="text-xl font-semibold mt-3">{service.title}</h3>
    <p class="mt-2 line-clamp-5 text-[15px] font-light">
      {service.description}
    </p>
  </div>
</div>

<style>
  .cards {
    position: relative;
  }

  .btn-cotizar {
    position: absolute;
    top: 25px;
    right: 0;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
    background: var(--color-primary);
    color: #000;
    border: none;
    z-index: 10;
  }

  .btn-cotizar:hover {
    background: var(--color-accent);
    color: var(--color-text);
  }

  .cards:hover .btn-cotizar {
    transform: translateX(6px);
  }
</style>

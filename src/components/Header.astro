---
import { Picture } from 'astro:assets';
import logo from '../assets/logos/logo-arviseg.png';
// components/Header.astro
---

<header class="py-4 px-12 flex gap-4 justify-between">
  <Picture class="size-16" src={logo} formats={['png']} alt="logo arviseg" />
  <nav class="flex gap-4 h-fit">
    <a class="p-2" href="/#home">Inicio</a>
    <a class="p-2" href="/#about">Nosotros</a>
    <a class="p-2" href="/services/">Servicios</a>
    <a class="p-2" href="/contact/">Contacto</a>
  </nav>
  <a href="#contact" class="py-2 px-4 h-fit"> Contáctanos </a>
</header>

---
import { Picture } from 'astro:assets';
import logo from '../assets/logos/logo-arviseg.png';
import MiniBanner from '../components/MiniBanner.astro';

const currentPage = Astro.url.pathname;
---

<div class="hidden md:block">
  <MiniBanner />
</div>
<header id="home" class="header sticky top-0 z-50 backdrop-blur-[1px]">
  <!-- Barra principal -->
  <div
    id="main-bar"
    class="m-auto px-6 md:px-12 py-2 flex items-center justify-between"
  >
    <a href="/#"
      ><Picture
        class="size-16"
        src={logo}
        formats={['png']}
        alt="logo arviseg"
      /></a
    >

    <!-- Links escritorio -->
    <nav class="desk-nav hidden md:flex gap-4">
      <a class="p-2 nav-link nav-home" href="/#">Inicio</a>
      <a class="p-2 nav-link nav-about" href="/#about">Nosotros</a>
      <a class="p-2 nav-link nav-services" href="/services/">Servicios</a>
      <a class="p-2 nav-link nav-contact" href="/contact/">Contacto</a>
    </nav>

    <div class="flex gap-4 items-center">
      <a
        href="/contact/"
        class="bg-primary text-color action-hover text-dark py-2 px-4"
      >
        Contáctanos
      </a>

      <!-- Botón hamburguesa -->
      <button id="menu-btn" class="md:hidden p-2">
        <!-- Icono hamburguesa -->
        <svg
          id="hamburger"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <!-- Icono X -> oculto inicialmente -->
        <svg
          id="close"
          class="w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="menu hidden md:hidden absolute top-full left-0 w-full bg-white shadow-lg flex-col"
  >
    <nav class="lines2 flex flex-col">
      <a class="menu-effect p-4 pl-12 nav-link nav-home" href="/#home">Inicio</a
      >
      <a class="menu-effect p-4 pl-12 nav-link nav-about" href="/#about"
        >Nosotros</a
      >
      <a class="menu-effect p-4 pl-12 nav-link nav-services" href="/services/"
        >Servicios</a
      >
      <a class="menu-effect p-4 pl-12 nav-link nav-contact" href="/contact/"
        >Contacto</a
      >
    </nav>
    <div class="py-6">
      <MiniBanner />
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger');
  const close = document.getElementById('close');
  const mainBar = document.getElementById('main-bar');

  function closeMenu() {
    if (!menu || menu.classList.contains('hidden')) return;
    menu.classList.add('hidden');
    menu.classList.remove('flex');
    mainBar?.classList.remove('menu-open');
    if (hamburger && close) {
      hamburger.classList.remove('hidden');
      close.classList.add('hidden');
    }
  }

  function openMenu() {
    if (!menu || !menu.classList.contains('hidden')) return;
    menu.classList.remove('hidden');
    menu.classList.add('flex');
    mainBar?.classList.add('menu-open');
    if (hamburger && close) {
      hamburger.classList.add('hidden');
      close.classList.remove('hidden');
    }
  }

  if (btn && menu && hamburger && close) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !menu.classList.contains('hidden');
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Cerrar al hacer clic fuera del menú o del botón
    document.addEventListener('click', (e) => {
      if (menu.classList.contains('hidden')) return;
      const target = e.target;
      if (!(target instanceof Node)) return;
      if (menu.contains(target) || btn.contains(target)) return;
      closeMenu();
    });

    // Cerrar al redimensionar
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) {
        closeMenu();
      }
    });
  }
</script>

<script>
  const header = document.querySelector('.header');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>

<script>
  // Solo para el link de about en home
  if (window.location.pathname === '/' || window.location.pathname === '') {
    const aboutSection = document.getElementById('about');
    const aboutLink = document.querySelectorAll('.nav-about');
    const homeLink = document.querySelectorAll('.nav-home');
    const servicesLink = document.querySelectorAll('.nav-services');
    const contactLink = document.querySelectorAll('.nav-contact');

    // Resetear todos
    function resetActive() {
      homeLink.forEach((link) => link?.classList.remove('active'));
      aboutLink.forEach((link) => link?.classList.remove('active'));
      servicesLink.forEach((link) => link?.classList.remove('active'));
      contactLink.forEach((link) => link?.classList.remove('active'));
    }

    // Activar home por defecto al cargar
    resetActive();
    homeLink.forEach((link) => link?.classList.add('active'));

    // Activar según scroll
    window.addEventListener('scroll', () => {
      const aboutPosition = aboutSection?.getBoundingClientRect();
      const homePosition = document
        .getElementById('home')
        ?.getBoundingClientRect();

      if (
        aboutPosition &&
        aboutPosition.top <= 150 &&
        aboutPosition.bottom >= 150
      ) {
        resetActive();
        aboutLink.forEach((link) => link?.classList.add('active'));
      } else if (homePosition && homePosition.top <= 150) {
        resetActive();
        homeLink.forEach((link) => link?.classList.add('active'));
      }
    });
  }

  // Para otras paginas
  const currentPath = window.location.pathname;
  if (currentPath === '/services/') {
    document
      .querySelectorAll('.nav-services')
      .forEach((link) => link?.classList.add('active'));
  }
  if (currentPath === '/contact/') {
    document
      .querySelectorAll('.nav-contact')
      .forEach((link) => link?.classList.add('active'));
  }
</script>

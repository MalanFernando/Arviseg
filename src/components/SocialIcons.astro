---
import { url } from 'astro:schema';
import Facebook from '../icons/socialMedia/facebook.svg';
import Instagram from '../icons/socialMedia/instagram.svg';
import Twitter from '../icons/socialMedia/twitter.svg';

const socialIcons = [
  {
    name: 'Facebook',
    component: Facebook,
    url: 'https://www.facebook.com/arviseg'
  },
  {
    name: 'Instagram',
    component: Instagram,
    url: 'https://www.instagram.com/arviseg'
  },
  { name: 'Twitter', component: Twitter, url: 'https://twitter.com/arviseg' }
];
---

<div class="">
  <ul class="flex gap-4">
    {
      socialIcons.map((icon) => (
        <li>
          <a href={icon.url} target="_blank" rel="noopener noreferrer">
            <icon.component />
          </a>
        </li>
      ))
    }
  </ul>
</div>
